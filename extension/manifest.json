{
  "manifest_version": 2,
  "name": "Phishing Detector",
  "version": "1.0",
  "description": "Detect phishing websites.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "browser_action": {
    "default_popup": "pop.html",
    "default_icon": {
      "16": "icon.png"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}

